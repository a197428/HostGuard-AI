{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "skipLibCheck": true,
    "lib": ["ES2022"],
    "types": ["@cloudflare/workers-types", "vitest/globals"],
    "paths": {
      "@hostguard/shared": ["./src/shared/index"],
      "@hostguard/shared/*": ["./src/shared/*"],
      "@hostguard/backend": ["./src/backend/index"],
      "@hostguard/backend/*": ["./src/backend/*"],
      "@hostguard/frontend": ["./src/frontend/index"]
    }
  },
  "include": ["src/backend/**/*.ts", "src/shared/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", ".wrangler", "src/frontend"]
}
