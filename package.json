{
  "name": "hostguard-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "src/backend",
    "src/frontend",
    "src/shared",
    "tests"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=src/backend",
    "dev:frontend": "npm run dev --workspace=src/frontend",
    "build": "npm run build --workspace=src/backend && npm run build --workspace=src/frontend",
    "ai-eval": "vitest run tests/ai-eval-suite.test.ts",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.51.0",
    "@upstash/redis": "^1.37.0"
  }
}
